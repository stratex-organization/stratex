# ─────────────────────────────────────────────────────────────
# Stratex Frontend — variables de entorno (plantilla)
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA comitees .env.local ni secretos. El frontend NO debe tener DATABASE_URL.
# ─────────────────────────────────────────────────────────────

# URL pública de la API REST de Python (FastAPI).
# Expuesta al navegador (prefijo NEXT_PUBLIC_), así que solo URL, sin secretos.
NEXT_PUBLIC_API_URL="http://localhost:8000"

# (Opcional) URL del backend para llamadas servidor→servidor (Auth.js / server actions).
# Útil si en producción el frontend alcanza el backend por una URL interna distinta.
# Si se omite, se usa NEXT_PUBLIC_API_URL.
# API_INTERNAL_URL="http://localhost:8000"

# URL de la API oficial de Stratex (contenido: publicaciones, stats, radar, fuentes).
# SOLO servidor — sin prefijo NEXT_PUBLIC_. El navegador la consume vía el proxy /api/stratex.
# Si se omite, se usa la de producción por defecto.
STRATEX_API_URL="https://stratex-api-production.up.railway.app"

# (Opcional, futuro) Clave para acciones de escritura de la API oficial (x-api-key).
# SOLO servidor. No se usa todavía (integración en modo solo lectura).
# STRATEX_API_KEY=""

# Auth.js (NextAuth v5)
# Genera uno con: npx auth secret   (o: openssl rand -base64 32)
AUTH_SECRET="reemplazar-con-secreto-generado"
# URL canónica del frontend (en prod la setea Vercel automáticamente).
# AUTH_URL="http://localhost:3000"
