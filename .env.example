# =====================================================================
#  StrateX RegTech — Plantilla de variables de entorno
#  Copia este archivo a ".env" y rellena los valores reales.
#  (El archivo .env NO debe subirse al repositorio.)
# =====================================================================

# --- Conexión a PostgreSQL ---
# Opción A: cadena completa (tiene prioridad si está definida)
# Formato: postgresql+psycopg2://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL=postgresql+psycopg2://stratex:stratex@localhost:5432/stratex_db

# Opción B: piezas individuales (se usan solo si DATABASE_URL está vacía)
POSTGRES_USER=stratex
POSTGRES_PASSWORD=stratex
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stratex_db

# --- Configuración del scraper DOF ---
# Feed RSS "Sumario" del Diario Oficial (Estrategia A). Si cambia, actualízalo.
DOF_RSS_URL=https://www.dof.gob.mx/sumario.xml
# Página de índice para el fallback HTML (Estrategia B)
DOF_INDEX_URL=https://www.dof.gob.mx/

# --- Comportamiento de red ---
# Retraso aleatorio mínimo/máximo (segundos) entre peticiones
SCRAPER_MIN_DELAY=1
SCRAPER_MAX_DELAY=3
# Activa logs de nivel DEBUG (true/false)
DEBUG=false
