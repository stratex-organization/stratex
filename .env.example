# =====================================================================
#  StrateX RegTech — Plantilla de variables de entorno
#  Copia este archivo a ".env" y rellena los valores reales.
#  (El archivo .env NO debe subirse al repositorio.)
# =====================================================================

# --- Conexión a PostgreSQL ---
# Opción A: cadena completa (tiene prioridad si está definida)
# Formato: postgresql+psycopg2://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS
DATABASE_URL=postgresql+psycopg2://stratex:stratex@localhost:5432/stratex_db

# Opción B: piezas individuales (se usan solo si DATABASE_URL está vacía)
POSTGRES_USER=stratex
POSTGRES_PASSWORD=stratex
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stratex_db

# --- Configuración del scraper DOF ---
# Feed RSS "Sumario" del Diario Oficial (Estrategia A). Si cambia, actualízalo.
DOF_RSS_URL=https://www.dof.gob.mx/sumario.xml
# Página de índice para el fallback HTML (Estrategia B)
DOF_INDEX_URL=https://www.dof.gob.mx/

# --- Capa de IA (DeepSeek; API compatible con OpenAI) ---
# Obtén tu API key en https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...
AI_BASE_URL=https://api.deepseek.com
# Modelo: "deepseek-chat" (V3, rápido) o "deepseek-reasoner" (R1, razonamiento)
AI_MODEL=deepseek-chat
# Cuántas publicaciones procesar por corrida (0 = todas las pendientes)
AI_BATCH_LIMIT=25

# --- Fuentes adicionales (multi-fuente) ---
# Fuentes activas (coma): DOF, CNBV, SAT, BANXICO, DIPUTADOS, SENADO
# CNBV ya funciona vía ScrapingBee (gob.mx). Las demás requieren ScrapingBee
# (SCRAPINGBEE_KEY) y, algunas, un parser dedicado.
ENABLED_SOURCES=DOF,CNBV
CNBV_RSS_URL=https://www.gob.mx/cnbv/rss
SAT_RSS_URL=https://www.gob.mx/sat/rss
BANXICO_RSS_URL=https://www.banxico.org.mx/rss/rss.xml
DIPUTADOS_RSS_URL=https://gaceta.diputados.gob.mx/rss/gaceta.xml

# --- Texto completo ---
# Descargar el cuerpo completo de cada nota nueva (mejora el análisis de IA)
FETCH_FULL_TEXT=true

# --- Alertas ---
# Niveles que disparan alerta (coma): Alta, Media, Baja
ALERT_NIVELES=Alta
# Sectores vigilados (coma); vacío = todos
ALERT_SECTORES=
# Slack (webhook entrante). Vacío = desactivado
SLACK_WEBHOOK_URL=
# Correo SMTP (todos requeridos para activar email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# --- Scraping API / Proxy (sortea WAF y bloqueo por IP extranjera) ---
# ScrapingBee: pon tu token y las fuentes bloqueadas se enrutan por IP de MX
# con render de JS (vence anti-bot de gob.mx, Senado, Diputados, etc.).
SCRAPINGBEE_KEY=
SCRAPINGBEE_COUNTRY=mx
SCRAPINGBEE_PREMIUM=true
# Alternativa: proxy residencial MX (Bright Data / Oxylabs / Webshare):
#   SCRAPER_PROXY_URL=http://usuario:password@host:puerto
SCRAPER_PROXY_URL=
SCRAPER_PROXY_VERIFY=true

# --- Comportamiento de red ---
# Retraso aleatorio mínimo/máximo (segundos) entre peticiones
SCRAPER_MIN_DELAY=1
SCRAPER_MAX_DELAY=3
# Activa logs de nivel DEBUG (true/false)
DEBUG=false
